{
  "expo": {
    "name": "Add_To_Ride",
    "slug": "Add_To_Ride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/add-to-rides-blue.png",
    "scheme": "addtoride",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#87CBDE",
        "foregroundImage": "./assets/images/add-to-rides-blue.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kylxgxy.Add_To_Ride"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/add-to-rides-blue.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/add-to-rides-blue.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#87CBDE",
          "dark": {
            "backgroundColor": "#87CBDE"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef0eb40a-43d1-4535-be37-6d99b39dd745"
      }
    },
    "owner": "kylxgxy",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ef0eb40a-43d1-4535-be37-6d99b39dd745"
    }
  }
}
